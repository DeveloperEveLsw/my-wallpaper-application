<Window x:Class="Wallpaper.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="My Wallpaper Application"
        Width="1440"
        Height="900"
        MinWidth="1024"
        MinHeight="640"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        WindowState="Maximized"
        Background="#090D18"
        Foreground="#F7F9FF"
        DpiChanged="Window_OnDpiChanged"
        KeyDown="Window_OnKeyDown"
        MouseLeave="Window_OnMouseLeave"
        PreviewMouseLeftButtonUp="Window_OnPreviewMouseLeftButtonUp"
        PreviewMouseMove="Window_OnPreviewMouseMove"
        SizeChanged="Window_OnSizeChanged">
    <Window.Resources>
        <Style x:Key="GlassButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="#F7F9FF" />
            <Setter Property="Background" Value="#22FFFFFF" />
            <Setter Property="BorderBrush" Value="#3DFFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Chrome"
                                Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#36FFFFFF" />
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#66FFFFFF" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#4AFFFFFF" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Chrome" Property="Opacity" Value="0.42" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CardButtonStyle" TargetType="Button" BasedOn="{StaticResource GlassButtonStyle}">
            <Setter Property="Width" Value="88" />
            <Setter Property="Height" Value="106" />
            <Setter Property="Padding" Value="8" />
            <Setter Property="Margin" Value="4,0" />
            <Setter Property="Background" Value="#08FFFFFF" />
            <Setter Property="BorderBrush" Value="Transparent" />
        </Style>

        <Style x:Key="PanelTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="20" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#F7F9FF" />
        </Style>
    </Window.Resources>

    <Grid x:Name="CompositionRoot">
        <!-- Wallpaper Render Layer: placeholder only. -->
        <Grid IsHitTestVisible="False">
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Offset="0" Color="#09101E" />
                    <GradientStop Offset="0.48" Color="#111B33" />
                    <GradientStop Offset="1" Color="#101524" />
                </LinearGradientBrush>
            </Grid.Background>
            <Ellipse Width="760"
                     Height="760"
                     Margin="-180,-260,0,0"
                     HorizontalAlignment="Left"
                     VerticalAlignment="Top"
                     Fill="#382F7FE5">
                <Ellipse.Effect>
                    <BlurEffect Radius="110" />
                </Ellipse.Effect>
            </Ellipse>
            <Ellipse Width="620"
                     Height="620"
                     Margin="0,0,-180,-240"
                     HorizontalAlignment="Right"
                     VerticalAlignment="Bottom"
                     Fill="#2B9A4FAD">
                <Ellipse.Effect>
                    <BlurEffect Radius="120" />
                </Ellipse.Effect>
            </Ellipse>
        </Grid>

        <!-- Background input surface. UI elements above it own their own hit test regions. -->
        <Border Background="Transparent"
                MouseLeftButtonDown="BackgroundSurface_OnMouseLeftButtonDown"
                MouseRightButtonUp="BackgroundSurface_OnMouseRightButtonUp" />

        <!-- Desktop UI Layer. -->
        <Grid>
            <StackPanel Margin="0,44,0,0"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Top"
                        IsHitTestVisible="False">
                <TextBlock x:Name="ClockText"
                           HorizontalAlignment="Center"
                           FontFamily="Segoe UI Variable Display"
                           FontSize="44"
                           FontWeight="Light"
                           Text="00:00" />
                <TextBlock x:Name="DateText"
                           Margin="0,4,0,0"
                           HorizontalAlignment="Center"
                           FontSize="13"
                           Foreground="#AFC2D2E8"
                           Text="날짜" />
            </StackPanel>

            <Border Width="760"
                    Height="470"
                    Margin="28,28,28,170"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Bottom"
                    Padding="22"
                    Background="#D41A2131"
                    BorderBrush="#55FFFFFF"
                    BorderThickness="1"
                    CornerRadius="28"
                    Visibility="{Binding IsModalOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="34" Opacity="0.35" ShadowDepth="12" />
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid>
                        <TextBlock Style="{StaticResource PanelTitleStyle}"
                                   VerticalAlignment="Center"
                                   Text="{Binding ModalTitle}" />
                        <TextBlock Margin="0,0,52,0"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Center"
                                   FontSize="12"
                                   Foreground="#AFC2D2E8"
                                   Text="{Binding VisibleFileCountText}" />
                        <Button Width="34"
                                Height="34"
                                HorizontalAlignment="Right"
                                Padding="0"
                                Command="{Binding CloseModalCommand}"
                                Content="×"
                                FontSize="19"
                                Style="{StaticResource GlassButtonStyle}" />
                    </Grid>

                    <Grid Grid.Row="1" Margin="0,20,0,0">
                        <ListBox ItemsSource="{Binding VisibleFileRows}"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 ScrollViewer.CanContentScroll="True"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 VirtualizingPanel.IsVirtualizing="True"
                                 VirtualizingPanel.VirtualizationMode="Recycling">
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <VirtualizingStackPanel />
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    <Setter Property="IsHitTestVisible" Value="True" />
                                    <Setter Property="Focusable" Value="False" />
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <ContentPresenter />
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <ItemsControl ItemsSource="{Binding Files}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border x:Name="FileTileChrome"
                                                        AutomationProperties.AutomationId="{Binding File.Id}"
                                                        Width="128"
                                                        Height="122"
                                                        Margin="4"
                                                        Padding="8"
                                                        CornerRadius="16"
                                                        Cursor="Hand"
                                                        Focusable="True"
                                                        KeyDown="FileTile_OnKeyDown"
                                                        MouseLeftButtonDown="FileTile_OnMouseLeftButtonDown"
                                                        MouseRightButtonDown="FileTile_OnMouseRightButtonDown"
                                                        ToolTip="{Binding Name}">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="#0AFFFFFF" />
                                                            <Setter Property="BorderBrush" Value="Transparent" />
                                                            <Setter Property="BorderThickness" Value="1" />
                                                            <Style.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter Property="Background" Value="#20FFFFFF" />
                                                                    <Setter Property="BorderBrush" Value="#42FFFFFF" />
                                                                </Trigger>
                                                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                    <Setter Property="Background" Value="#3D6FA8E8" />
                                                                    <Setter Property="BorderBrush" Value="#B7B9DAFF" />
                                                                    <Setter Property="BorderThickness" Value="2" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <StackPanel VerticalAlignment="Center">
                                                        <Grid Width="58" Height="62" HorizontalAlignment="Center">
                                                            <Border Background="#22FFFFFF"
                                                                    BorderBrush="#44FFFFFF"
                                                                    BorderThickness="1"
                                                                    CornerRadius="10">
                                                                <TextBlock HorizontalAlignment="Center"
                                                                           VerticalAlignment="Center"
                                                                           FontSize="12"
                                                                           FontWeight="Bold"
                                                                           Foreground="#DDEBFAFF"
                                                                           Text="{Binding ExtensionLabel}" />
                                                            </Border>
                                                            <Image Width="58"
                                                                   Height="62"
                                                                   Loaded="FileVisual_OnLoaded"
                                                                   RenderOptions.BitmapScalingMode="HighQuality"
                                                                   SizeChanged="FileVisual_OnSizeChanged"
                                                                   Source="{Binding Visual}"
                                                                   Stretch="Uniform" />
                                                        </Grid>
                                                        <TextBlock Margin="0,8,0,0"
                                                                   HorizontalAlignment="Center"
                                                                   FontSize="12"
                                                                   Text="{Binding Name}"
                                                                   TextAlignment="Center"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   TextWrapping="NoWrap" />
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <TextBlock HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontSize="14"
                                   Foreground="#91A7B9CE"
                                   Text="이 폴더에는 표시할 파일이 없습니다.">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasVisibleFiles}" Value="False">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                </Grid>
            </Border>

            <Border x:Name="DockContainer"
                    Margin="20,0,20,28"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Bottom"
                    Padding="12,10"
                    Background="#C91B2334"
                    BorderBrush="#5CFFFFFF"
                    BorderThickness="1"
                    CornerRadius="28">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="28" Opacity="0.38" ShadowDepth="10" />
                </Border.Effect>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <ScrollViewer MaxHeight="110"
                                  HorizontalScrollBarVisibility="Hidden"
                                  PanningMode="HorizontalOnly"
                                  VerticalScrollBarVisibility="Disabled">
                        <Grid>
                            <ItemsControl ItemsSource="{Binding FolderCards}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button AutomationProperties.AutomationId="{Binding Id}"
                                                Command="{Binding DataContext.OpenCardCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"
                                                PreviewKeyDown="DockCard_OnPreviewKeyDown"
                                                PreviewMouseLeftButtonDown="DockCard_OnPreviewMouseLeftButtonDown"
                                                PreviewMouseRightButtonDown="DockCard_OnPreviewMouseRightButtonDown"
                                                Style="{StaticResource CardButtonStyle}">
                                            <Grid>
                                                <StackPanel>
                                                    <Grid Width="58" Height="58" HorizontalAlignment="Center">
                                                        <Path Margin="2,7,2,3"
                                                              Data="M 4,15 L 22,15 L 28,8 L 52,8 Q 56,8 56,13 L 56,47 Q 56,52 51,52 L 7,52 Q 2,52 2,47 L 2,20 Q 2,15 4,15 Z"
                                                              Fill="#ECA4C7FF"
                                                              Stretch="Fill" />
                                                        <Path Margin="5,16,5,6"
                                                              Data="M 2,4 Q 2,0 7,0 L 45,0 Q 50,0 50,5 L 50,33 Q 50,38 45,38 L 7,38 Q 2,38 2,33 Z"
                                                              Fill="#B7659DE8"
                                                              Stretch="Fill" />
                                                    </Grid>
                                                    <TextBlock Margin="2,5,2,0"
                                                               HorizontalAlignment="Center"
                                                               FontSize="12"
                                                               Text="{Binding Name}"
                                                               TextAlignment="Center"
                                                               TextTrimming="CharacterEllipsis" />
                                                </StackPanel>
                                                <Border x:Name="ValidFileDropIndicator"
                                                        Padding="6"
                                                        Background="#D0357555"
                                                        BorderBrush="#D99BE7B8"
                                                        BorderThickness="2"
                                                        CornerRadius="14"
                                                        IsHitTestVisible="False"
                                                        Visibility="Collapsed">
                                                    <TextBlock HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               FontSize="11"
                                                               FontWeight="SemiBold"
                                                               Text="여기로 이동"
                                                               TextAlignment="Center" />
                                                </Border>
                                                <Border x:Name="InvalidFileDropIndicator"
                                                        Padding="6"
                                                        Background="#D06B2E36"
                                                        BorderBrush="#E7FF9CA5"
                                                        BorderThickness="2"
                                                        CornerRadius="14"
                                                        IsHitTestVisible="False"
                                                        Visibility="Collapsed">
                                                    <TextBlock HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               FontSize="11"
                                                               FontWeight="SemiBold"
                                                               Text="이동 불가"
                                                               TextAlignment="Center" />
                                                </Border>
                                                <Border x:Name="InsertBeforeIndicator"
                                                        Width="3"
                                                        Margin="-5,7,0,7"
                                                        HorizontalAlignment="Left"
                                                        Background="#D7A9D0FF"
                                                        CornerRadius="2"
                                                        Visibility="Collapsed" />
                                                <Border x:Name="InsertAfterIndicator"
                                                        Width="3"
                                                        Margin="0,7,-5,7"
                                                        HorizontalAlignment="Right"
                                                        Background="#D7A9D0FF"
                                                        CornerRadius="2"
                                                        Visibility="Collapsed" />
                                            </Grid>
                                        </Button>
                                        <DataTemplate.Triggers>
                                            <DataTrigger Binding="{Binding ShowInsertBefore}" Value="True">
                                                <Setter TargetName="InsertBeforeIndicator" Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding ShowInsertAfter}" Value="True">
                                                <Setter TargetName="InsertAfterIndicator" Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsFileDropTargetValid}" Value="True">
                                                <Setter TargetName="ValidFileDropIndicator" Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsFileDropTargetInvalid}" Value="True">
                                                <Setter TargetName="InvalidFileDropIndicator" Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </DataTemplate.Triggers>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <TextBlock MinWidth="120"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontSize="12"
                                       Foreground="#91A7B9CE"
                                       Text="폴더 없음">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding DataContext.HasFolderCards, RelativeSource={RelativeSource AncestorType=Window}}" Value="False">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </ScrollViewer>

                    <Border Grid.Column="1"
                            Width="1"
                            Height="70"
                            Margin="12,10"
                            VerticalAlignment="Center"
                            Background="#5AFFFFFF" />

                    <Button Grid.Column="2"
                            AutomationProperties.AutomationId="{Binding Id}"
                            Command="{Binding DataContext.OpenCardCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                            CommandParameter="{Binding}"
                            DataContext="{Binding RootFilesCard}"
                            Style="{StaticResource CardButtonStyle}">
                        <Grid>
                            <StackPanel>
                                <Border Width="58"
                                        Height="58"
                                        HorizontalAlignment="Center"
                                        Background="#16FFFFFF"
                                        BorderBrush="#52FFFFFF"
                                        BorderThickness="1"
                                        CornerRadius="18">
                                    <TextBlock HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               FontFamily="Segoe UI Variable Display"
                                               FontSize="32"
                                               FontWeight="Light"
                                               Text="…" />
                                </Border>
                                <TextBlock Margin="0,5,0,0"
                                           HorizontalAlignment="Center"
                                           FontSize="12"
                                           Text="…" />
                            </StackPanel>
                            <Border Padding="6"
                                    Background="#D0357555"
                                    BorderBrush="#D99BE7B8"
                                    BorderThickness="2"
                                    CornerRadius="14"
                                    IsHitTestVisible="False">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsFileDropTargetValid}" Value="True">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Text="루트로 이동"
                                           TextAlignment="Center" />
                            </Border>
                            <Border Padding="6"
                                    Background="#D06B2E36"
                                    BorderBrush="#E7FF9CA5"
                                    BorderThickness="2"
                                    CornerRadius="14"
                                    IsHitTestVisible="False">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsFileDropTargetInvalid}" Value="True">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Text="이동 불가"
                                           TextAlignment="Center" />
                            </Border>
                        </Grid>
                    </Button>
                </Grid>
            </Border>
        </Grid>

        <!-- Transient Layer: item commands, native Shell entry point, and file move UI. -->
        <Canvas Panel.ZIndex="4"
                Visibility="{Binding IsItemContextMenuOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Border Width="260"
                    Canvas.Left="{Binding ItemContextMenuLeft}"
                    Canvas.Top="{Binding ItemContextMenuTop}"
                    Padding="12"
                    Background="#F01A2131"
                    BorderBrush="#70FFFFFF"
                    BorderThickness="1"
                    CornerRadius="18">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="30" Opacity="0.48" ShadowDepth="10" />
                </Border.Effect>
                <StackPanel>
                    <Grid Margin="5,2,2,9">
                        <TextBlock Margin="0,0,32,0"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="#C9D9E7F7"
                                   Text="{Binding ItemContextTargetName}"
                                   TextTrimming="CharacterEllipsis" />
                        <Button Width="26"
                                Height="26"
                                HorizontalAlignment="Right"
                                Padding="0"
                                Command="{Binding CloseContextMenuCommand}"
                                Content="×"
                                Style="{StaticResource GlassButtonStyle}" />
                    </Grid>
                    <Button Margin="0,2"
                            AutomationProperties.AutomationId="ItemOpenMenu"
                            HorizontalContentAlignment="Left"
                            Command="{Binding OpenContextItemCommand}"
                            Content="열기"
                            Style="{StaticResource GlassButtonStyle}" />
                    <Button Margin="0,2"
                            AutomationProperties.AutomationId="ItemRevealMenu"
                            HorizontalContentAlignment="Left"
                            Command="{Binding ShowContextItemInExplorerCommand}"
                            Content="탐색기에서 위치 열기"
                            Style="{StaticResource GlassButtonStyle}" />
                    <Border Height="1" Margin="6,8" Background="#38FFFFFF" />
                    <Button Margin="0,2"
                            AutomationProperties.AutomationId="ItemRenameMenu"
                            HorizontalContentAlignment="Left"
                            Command="{Binding BeginRenameCommand}"
                            Content="이름 변경"
                            Style="{StaticResource GlassButtonStyle}" />
                    <Button Margin="0,2"
                            AutomationProperties.AutomationId="ItemRecycleMenu"
                            HorizontalContentAlignment="Left"
                            Background="#33D95E68"
                            Command="{Binding BeginRecycleCommand}"
                            Content="휴지통으로 이동"
                            Style="{StaticResource GlassButtonStyle}" />
                    <Border Height="1" Margin="6,8" Background="#38FFFFFF" />
                    <Button Margin="0,2"
                            AutomationProperties.AutomationId="ItemWindowsOptionsMenu"
                            HorizontalContentAlignment="Left"
                            Click="WindowsOptions_OnClick"
                            Content="Windows 추가 옵션 표시"
                            Style="{StaticResource GlassButtonStyle}" />
                </StackPanel>
            </Border>
        </Canvas>

        <Grid Panel.ZIndex="5"
              Background="#85070B13"
              Visibility="{Binding IsMoveDialogOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Border Width="470"
                    Padding="24"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="#F21A2131"
                    BorderBrush="#70FFFFFF"
                    BorderThickness="1"
                    CornerRadius="24">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="38" Opacity="0.5" ShadowDepth="12" />
                </Border.Effect>
                <StackPanel>
                    <TextBlock Style="{StaticResource PanelTitleStyle}" Text="이동할 이름 확인" />
                    <TextBlock Margin="0,9,0,6"
                               Foreground="#D7E2ECF7"
                               Text="{Binding MoveMessage}"
                               TextWrapping="Wrap" />
                    <TextBlock Margin="0,0,0,16"
                               FontSize="12"
                               Foreground="#AFC2D2E8"
                               Text="기존 항목은 덮어쓰지 않습니다. 제안 이름을 직접 편집할 수 있습니다."
                               TextWrapping="Wrap" />
                    <TextBox x:Name="MoveTextBox"
                             AutomationProperties.AutomationId="MoveNameInput"
                             MinHeight="44"
                             Padding="12,9"
                             Loaded="MoveTextBox_OnLoaded"
                             Background="#24FFFFFF"
                             BorderBrush="#5AFFFFFF"
                             BorderThickness="1"
                             CaretBrush="#FFFFFF"
                             FontSize="14"
                             Foreground="#F7F9FF"
                             MaxLength="255"
                             Text="{Binding MoveName, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBlock MinHeight="20"
                               Margin="2,8,2,0"
                               FontSize="12"
                               Foreground="#FFFFC278"
                               Text="{Binding MoveValidationMessage}"
                               TextWrapping="Wrap" />
                    <StackPanel Margin="0,20,0,0"
                                HorizontalAlignment="Right"
                                Orientation="Horizontal">
                        <Button IsCancel="True"
                                AutomationProperties.AutomationId="MoveCancel"
                                Command="{Binding CancelMoveCommand}"
                                Content="취소"
                                Style="{StaticResource GlassButtonStyle}" />
                        <Button Margin="8,0,0,0"
                                AutomationProperties.AutomationId="MoveConfirm"
                                IsDefault="True"
                                IsEnabled="{Binding CanConfirmMove}"
                                Command="{Binding ConfirmMoveCommand}"
                                Content="이동"
                                Style="{StaticResource GlassButtonStyle}" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <Grid Panel.ZIndex="5"
              Background="#85070B13"
              Visibility="{Binding IsRenameDialogOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Border Width="440"
                    Padding="24"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="#F21A2131"
                    BorderBrush="#70FFFFFF"
                    BorderThickness="1"
                    CornerRadius="24">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="38" Opacity="0.5" ShadowDepth="12" />
                </Border.Effect>
                <StackPanel>
                    <TextBlock Style="{StaticResource PanelTitleStyle}" Text="이름 변경" />
                    <TextBlock Margin="0,8,0,18"
                               FontSize="12"
                               Foreground="#AFC2D2E8"
                               Text="확장자를 포함한 전체 이름을 입력하세요." />
                    <TextBox x:Name="RenameTextBox"
                             AutomationProperties.AutomationId="RenameInput"
                             MinHeight="44"
                             Padding="12,9"
                             Loaded="RenameTextBox_OnLoaded"
                             Background="#24FFFFFF"
                             BorderBrush="#5AFFFFFF"
                             BorderThickness="1"
                             CaretBrush="#FFFFFF"
                             FontSize="14"
                             Foreground="#F7F9FF"
                             MaxLength="255"
                             Text="{Binding RenameText, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBlock MinHeight="20"
                               Margin="2,8,2,0"
                               FontSize="12"
                               Foreground="#FFFFA0A8"
                               Text="{Binding RenameValidationMessage}"
                               TextWrapping="Wrap" />
                    <StackPanel Margin="0,20,0,0"
                                HorizontalAlignment="Right"
                                Orientation="Horizontal">
                        <Button IsCancel="True"
                                AutomationProperties.AutomationId="RenameCancel"
                                Command="{Binding CancelRenameCommand}"
                                Content="취소"
                                Style="{StaticResource GlassButtonStyle}" />
                        <Button Margin="8,0,0,0"
                                AutomationProperties.AutomationId="RenameConfirm"
                                IsDefault="True"
                                IsEnabled="{Binding CanConfirmRename}"
                                Command="{Binding ConfirmRenameCommand}"
                                Content="변경"
                                Style="{StaticResource GlassButtonStyle}" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <Grid Panel.ZIndex="5"
              Background="#85070B13"
              Visibility="{Binding IsRecycleDialogOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Border Width="470"
                    Padding="24"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="#F21A2131"
                    BorderBrush="#70FFFFFF"
                    BorderThickness="1"
                    CornerRadius="24">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="38" Opacity="0.5" ShadowDepth="12" />
                </Border.Effect>
                <StackPanel>
                    <TextBlock Style="{StaticResource PanelTitleStyle}" Text="{Binding RecycleTitle}" />
                    <TextBlock Margin="0,13,0,0"
                               Foreground="#D7E2ECF7"
                               Text="{Binding RecycleMessage}"
                               TextWrapping="Wrap" />
                    <TextBlock MinHeight="20"
                               Margin="0,10,0,0"
                               FontSize="12"
                               Foreground="#FFFFA0A8"
                               Text="{Binding RecycleErrorMessage}"
                               TextWrapping="Wrap" />
                    <StackPanel Margin="0,20,0,0"
                                HorizontalAlignment="Right"
                                Orientation="Horizontal">
                        <Button IsCancel="True"
                                AutomationProperties.AutomationId="RecycleCancel"
                                Command="{Binding CancelRecycleCommand}"
                                Content="취소"
                                Style="{StaticResource GlassButtonStyle}" />
                        <Button Margin="8,0,0,0"
                                AutomationProperties.AutomationId="RecycleConfirm"
                                Padding="16,8"
                                IsDefault="True"
                                Background="#9FD34F5C"
                                Command="{Binding ConfirmRecycleCommand}"
                                Content="휴지통으로 이동"
                                Style="{StaticResource GlassButtonStyle}" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <Border Panel.ZIndex="6"
                MinWidth="320"
                MaxWidth="620"
                Margin="24,28,24,0"
                Padding="14,10"
                HorizontalAlignment="Center"
                VerticalAlignment="Top"
                BorderThickness="1"
                CornerRadius="16"
                Visibility="{Binding IsNotificationOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Background" Value="#E629563F" />
                    <Setter Property="BorderBrush" Value="#7899E1B5" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding NotificationIsError}" Value="True">
                            <Setter Property="Background" Value="#E65C2930" />
                            <Setter Property="BorderBrush" Value="#8BFF9CA5" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <Grid>
                <TextBlock Margin="0,0,34,0"
                           VerticalAlignment="Center"
                           Text="{Binding NotificationText}"
                           TextWrapping="Wrap" />
                <Button Width="28"
                        Height="28"
                        HorizontalAlignment="Right"
                        Padding="0"
                        Command="{Binding CloseNotificationCommand}"
                        Content="×"
                        Style="{StaticResource GlassButtonStyle}" />
            </Grid>
        </Border>

        <Border x:Name="FileDragPreview"
                Width="250"
                Panel.ZIndex="7"
                Padding="12,9"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Background="#F01A2131"
                BorderBrush="#9FB9DAFF"
                BorderThickness="1"
                CornerRadius="14"
                IsHitTestVisible="False"
                Opacity="0.94"
                Visibility="Collapsed">
            <Border.RenderTransform>
                <TranslateTransform x:Name="FileDragPreviewTransform" />
            </Border.RenderTransform>
            <StackPanel Orientation="Horizontal">
                <Border Width="30"
                        Height="30"
                        Background="#3D6FA8E8"
                        CornerRadius="9">
                    <TextBlock HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               FontSize="16"
                               Text="→" />
                </Border>
                <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
                    <TextBlock FontSize="11" Foreground="#AFC2D2E8" Text="파일 이동" />
                    <TextBlock x:Name="FileDragPreviewName"
                               MaxWidth="185"
                               FontSize="13"
                               FontWeight="SemiBold"
                               TextTrimming="CharacterEllipsis" />
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Transient Layer: hidden settings panel. -->
        <Border Width="390"
                Panel.ZIndex="2"
                Margin="0,28,28,0"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Padding="22"
                Background="#E61A2131"
                BorderBrush="#66FFFFFF"
                BorderThickness="1"
                CornerRadius="24"
                Visibility="{Binding IsSettingsOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Border.Effect>
                <DropShadowEffect BlurRadius="32" Opacity="0.4" ShadowDepth="10" />
            </Border.Effect>
            <StackPanel>
                <Grid>
                    <TextBlock Style="{StaticResource PanelTitleStyle}" Text="설정" />
                    <Button Width="34"
                            Height="34"
                            HorizontalAlignment="Right"
                            Padding="0"
                            Command="{Binding CloseSettingsCommand}"
                            Content="×"
                            FontSize="19"
                            Style="{StaticResource GlassButtonStyle}" />
                </Grid>

                <TextBlock Margin="0,24,0,7"
                           FontSize="12"
                           Foreground="#AFC2D2E8"
                           Text="월페이퍼 루트" />
                <Border MinHeight="44"
                        Padding="12,10"
                        Background="#18FFFFFF"
                        BorderBrush="#3FFFFFFF"
                        BorderThickness="1"
                        CornerRadius="12">
                    <TextBlock Text="{Binding RootPath, TargetNullValue=선택되지 않음}"
                               TextTrimming="CharacterEllipsis"
                               TextWrapping="NoWrap" />
                </Border>

                <StackPanel Margin="0,12,0,0" Orientation="Horizontal">
                    <Button Command="{Binding ChooseRootCommand}"
                            Content="폴더 선택"
                            Style="{StaticResource GlassButtonStyle}" />
                    <Button Margin="8,0,0,0"
                            Command="{Binding RescanCommand}"
                            Content="다시 스캔"
                            Style="{StaticResource GlassButtonStyle}" />
                </StackPanel>

                <Border Margin="0,22,0,0"
                        Padding="12"
                        Background="#0DFFFFFF"
                        CornerRadius="12">
                    <StackPanel>
                        <TextBlock FontWeight="SemiBold" Text="{Binding RootDisplayName}" />
                        <TextBlock Margin="0,5,0,0"
                                   FontSize="12"
                                   Foreground="#B6C9D7EA"
                                   Text="{Binding StatusText}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <TextBlock Margin="0,18,0,0"
                           FontSize="11"
                           Foreground="#8599A9C0"
                           Text="{Binding HostStatus}" />
            </StackPanel>
        </Border>

        <Border x:Name="SettingsHotspot"
                Width="72"
                Height="72"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Background="#01000000"
                MouseEnter="SettingsHotspot_OnMouseEnter"
                MouseLeave="SettingsHotspot_OnMouseLeave"
                MouseRightButtonUp="SettingsHotspot_OnMouseRightButtonUp" />
    </Grid>
</Window>
