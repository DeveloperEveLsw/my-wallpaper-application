<Window x:Class="Wallpaper.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="My Wallpaper Application"
        Width="1440"
        Height="900"
        MinWidth="1024"
        MinHeight="640"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        WindowState="Maximized"
        Background="#090D18"
        Foreground="#F7F9FF"
        KeyDown="Window_OnKeyDown"
        SizeChanged="Window_OnSizeChanged">
    <Window.Resources>
        <Style x:Key="GlassButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="#F7F9FF" />
            <Setter Property="Background" Value="#22FFFFFF" />
            <Setter Property="BorderBrush" Value="#3DFFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Chrome"
                                Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#36FFFFFF" />
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#66FFFFFF" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#4AFFFFFF" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Chrome" Property="Opacity" Value="0.42" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CardButtonStyle" TargetType="Button" BasedOn="{StaticResource GlassButtonStyle}">
            <Setter Property="Width" Value="88" />
            <Setter Property="Height" Value="106" />
            <Setter Property="Padding" Value="8" />
            <Setter Property="Margin" Value="4,0" />
            <Setter Property="Background" Value="#08FFFFFF" />
            <Setter Property="BorderBrush" Value="Transparent" />
        </Style>

        <Style x:Key="PanelTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="20" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#F7F9FF" />
        </Style>
    </Window.Resources>

    <Grid x:Name="CompositionRoot">
        <!-- Wallpaper Render Layer: placeholder only. -->
        <Grid IsHitTestVisible="False">
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Offset="0" Color="#09101E" />
                    <GradientStop Offset="0.48" Color="#111B33" />
                    <GradientStop Offset="1" Color="#101524" />
                </LinearGradientBrush>
            </Grid.Background>
            <Ellipse Width="760"
                     Height="760"
                     Margin="-180,-260,0,0"
                     HorizontalAlignment="Left"
                     VerticalAlignment="Top"
                     Fill="#382F7FE5">
                <Ellipse.Effect>
                    <BlurEffect Radius="110" />
                </Ellipse.Effect>
            </Ellipse>
            <Ellipse Width="620"
                     Height="620"
                     Margin="0,0,-180,-240"
                     HorizontalAlignment="Right"
                     VerticalAlignment="Bottom"
                     Fill="#2B9A4FAD">
                <Ellipse.Effect>
                    <BlurEffect Radius="120" />
                </Ellipse.Effect>
            </Ellipse>
        </Grid>

        <!-- Background input surface. UI elements above it own their own hit test regions. -->
        <Border Background="Transparent"
                MouseLeftButtonDown="BackgroundSurface_OnMouseLeftButtonDown" />

        <!-- Desktop UI Layer. -->
        <Grid>
            <StackPanel Margin="0,44,0,0"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Top"
                        IsHitTestVisible="False">
                <TextBlock x:Name="ClockText"
                           HorizontalAlignment="Center"
                           FontFamily="Segoe UI Variable Display"
                           FontSize="44"
                           FontWeight="Light"
                           Text="00:00" />
                <TextBlock x:Name="DateText"
                           Margin="0,4,0,0"
                           HorizontalAlignment="Center"
                           FontSize="13"
                           Foreground="#AFC2D2E8"
                           Text="날짜" />
            </StackPanel>

            <Border Width="760"
                    Height="470"
                    Margin="28,28,28,170"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Bottom"
                    Padding="22"
                    Background="#D41A2131"
                    BorderBrush="#55FFFFFF"
                    BorderThickness="1"
                    CornerRadius="28"
                    Visibility="{Binding IsModalOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="34" Opacity="0.35" ShadowDepth="12" />
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid>
                        <TextBlock Style="{StaticResource PanelTitleStyle}"
                                   VerticalAlignment="Center"
                                   Text="{Binding ModalTitle}" />
                        <TextBlock Margin="0,0,52,0"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Center"
                                   FontSize="12"
                                   Foreground="#AFC2D2E8"
                                   Text="{Binding VisibleFileCountText}" />
                        <Button Width="34"
                                Height="34"
                                HorizontalAlignment="Right"
                                Padding="0"
                                Command="{Binding CloseModalCommand}"
                                Content="×"
                                FontSize="19"
                                Style="{StaticResource GlassButtonStyle}" />
                    </Grid>

                    <Grid Grid.Row="1" Margin="0,20,0,0">
                        <ListBox ItemsSource="{Binding VisibleFileRows}"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 ScrollViewer.CanContentScroll="True"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 VirtualizingPanel.IsVirtualizing="True"
                                 VirtualizingPanel.VirtualizationMode="Recycling">
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <VirtualizingStackPanel />
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    <Setter Property="IsHitTestVisible" Value="True" />
                                    <Setter Property="Focusable" Value="False" />
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <ContentPresenter />
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <ItemsControl ItemsSource="{Binding Files}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Width="128"
                                                        Height="122"
                                                        Margin="4"
                                                        Padding="8"
                                                        Background="#0AFFFFFF"
                                                        BorderBrush="Transparent"
                                                        BorderThickness="1"
                                                        CornerRadius="16"
                                                        ToolTip="{Binding Name}">
                                                    <StackPanel VerticalAlignment="Center">
                                                        <Grid Width="58" Height="62" HorizontalAlignment="Center">
                                                            <Border Background="#22FFFFFF"
                                                                    BorderBrush="#44FFFFFF"
                                                                    BorderThickness="1"
                                                                    CornerRadius="10">
                                                                <TextBlock HorizontalAlignment="Center"
                                                                           VerticalAlignment="Center"
                                                                           FontSize="12"
                                                                           FontWeight="Bold"
                                                                           Foreground="#DDEBFAFF"
                                                                           Text="{Binding ExtensionLabel}" />
                                                            </Border>
                                                            <Image Width="58"
                                                                   Height="62"
                                                                   Loaded="FileVisual_OnLoaded"
                                                                   Source="{Binding Visual}"
                                                                   Stretch="Uniform" />
                                                        </Grid>
                                                        <TextBlock Margin="0,8,0,0"
                                                                   HorizontalAlignment="Center"
                                                                   FontSize="12"
                                                                   Text="{Binding Name}"
                                                                   TextAlignment="Center"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   TextWrapping="NoWrap" />
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <TextBlock HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontSize="14"
                                   Foreground="#91A7B9CE"
                                   Text="이 폴더에는 표시할 파일이 없습니다.">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasVisibleFiles}" Value="False">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                </Grid>
            </Border>

            <Border x:Name="DockContainer"
                    Margin="20,0,20,28"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Bottom"
                    Padding="12,10"
                    Background="#C91B2334"
                    BorderBrush="#5CFFFFFF"
                    BorderThickness="1"
                    CornerRadius="28">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="28" Opacity="0.38" ShadowDepth="10" />
                </Border.Effect>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <ScrollViewer MaxHeight="110"
                                  HorizontalScrollBarVisibility="Hidden"
                                  PanningMode="HorizontalOnly"
                                  VerticalScrollBarVisibility="Disabled">
                        <Grid>
                            <ItemsControl ItemsSource="{Binding FolderCards}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button AllowDrop="True"
                                                Command="{Binding DataContext.OpenCardCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"
                                                DragLeave="DockCard_OnDragLeave"
                                                DragOver="DockCard_OnDragOver"
                                                Drop="DockCard_OnDrop"
                                                PreviewMouseLeftButtonDown="DockCard_OnPreviewMouseLeftButtonDown"
                                                PreviewMouseMove="DockCard_OnPreviewMouseMove"
                                                Style="{StaticResource CardButtonStyle}">
                                            <Grid>
                                                <StackPanel>
                                                    <Grid Width="58" Height="58" HorizontalAlignment="Center">
                                                        <Path Margin="2,7,2,3"
                                                              Data="M 4,15 L 22,15 L 28,8 L 52,8 Q 56,8 56,13 L 56,47 Q 56,52 51,52 L 7,52 Q 2,52 2,47 L 2,20 Q 2,15 4,15 Z"
                                                              Fill="#ECA4C7FF"
                                                              Stretch="Fill" />
                                                        <Path Margin="5,16,5,6"
                                                              Data="M 2,4 Q 2,0 7,0 L 45,0 Q 50,0 50,5 L 50,33 Q 50,38 45,38 L 7,38 Q 2,38 2,33 Z"
                                                              Fill="#B7659DE8"
                                                              Stretch="Fill" />
                                                    </Grid>
                                                    <TextBlock Margin="2,5,2,0"
                                                               HorizontalAlignment="Center"
                                                               FontSize="12"
                                                               Text="{Binding Name}"
                                                               TextAlignment="Center"
                                                               TextTrimming="CharacterEllipsis" />
                                                </StackPanel>
                                                <Border x:Name="InsertBeforeIndicator"
                                                        Width="3"
                                                        Margin="-5,7,0,7"
                                                        HorizontalAlignment="Left"
                                                        Background="#D7A9D0FF"
                                                        CornerRadius="2"
                                                        Visibility="Collapsed" />
                                                <Border x:Name="InsertAfterIndicator"
                                                        Width="3"
                                                        Margin="0,7,-5,7"
                                                        HorizontalAlignment="Right"
                                                        Background="#D7A9D0FF"
                                                        CornerRadius="2"
                                                        Visibility="Collapsed" />
                                            </Grid>
                                        </Button>
                                        <DataTemplate.Triggers>
                                            <DataTrigger Binding="{Binding ShowInsertBefore}" Value="True">
                                                <Setter TargetName="InsertBeforeIndicator" Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding ShowInsertAfter}" Value="True">
                                                <Setter TargetName="InsertAfterIndicator" Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </DataTemplate.Triggers>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <TextBlock MinWidth="120"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontSize="12"
                                       Foreground="#91A7B9CE"
                                       Text="폴더 없음">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding DataContext.HasFolderCards, RelativeSource={RelativeSource AncestorType=Window}}" Value="False">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </ScrollViewer>

                    <Border Grid.Column="1"
                            Width="1"
                            Height="70"
                            Margin="12,10"
                            VerticalAlignment="Center"
                            Background="#5AFFFFFF" />

                    <Button Grid.Column="2"
                            Command="{Binding OpenCardCommand}"
                            CommandParameter="{Binding RootFilesCard}"
                            Style="{StaticResource CardButtonStyle}">
                        <StackPanel>
                            <Border Width="58"
                                    Height="58"
                                    HorizontalAlignment="Center"
                                    Background="#16FFFFFF"
                                    BorderBrush="#52FFFFFF"
                                    BorderThickness="1"
                                    CornerRadius="18">
                                <TextBlock HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           FontFamily="Segoe UI Variable Display"
                                           FontSize="32"
                                           FontWeight="Light"
                                           Text="…" />
                            </Border>
                            <TextBlock Margin="0,5,0,0"
                                       HorizontalAlignment="Center"
                                       FontSize="12"
                                       Text="…" />
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>
        </Grid>

        <!-- Transient Layer: hidden settings panel. -->
        <Border Width="390"
                Panel.ZIndex="2"
                Margin="0,28,28,0"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Padding="22"
                Background="#E61A2131"
                BorderBrush="#66FFFFFF"
                BorderThickness="1"
                CornerRadius="24"
                Visibility="{Binding IsSettingsOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Border.Effect>
                <DropShadowEffect BlurRadius="32" Opacity="0.4" ShadowDepth="10" />
            </Border.Effect>
            <StackPanel>
                <Grid>
                    <TextBlock Style="{StaticResource PanelTitleStyle}" Text="설정" />
                    <Button Width="34"
                            Height="34"
                            HorizontalAlignment="Right"
                            Padding="0"
                            Command="{Binding CloseSettingsCommand}"
                            Content="×"
                            FontSize="19"
                            Style="{StaticResource GlassButtonStyle}" />
                </Grid>

                <TextBlock Margin="0,24,0,7"
                           FontSize="12"
                           Foreground="#AFC2D2E8"
                           Text="월페이퍼 루트" />
                <Border MinHeight="44"
                        Padding="12,10"
                        Background="#18FFFFFF"
                        BorderBrush="#3FFFFFFF"
                        BorderThickness="1"
                        CornerRadius="12">
                    <TextBlock Text="{Binding RootPath, TargetNullValue=선택되지 않음}"
                               TextTrimming="CharacterEllipsis"
                               TextWrapping="NoWrap" />
                </Border>

                <StackPanel Margin="0,12,0,0" Orientation="Horizontal">
                    <Button Command="{Binding ChooseRootCommand}"
                            Content="폴더 선택"
                            Style="{StaticResource GlassButtonStyle}" />
                    <Button Margin="8,0,0,0"
                            Command="{Binding RescanCommand}"
                            Content="다시 스캔"
                            Style="{StaticResource GlassButtonStyle}" />
                </StackPanel>

                <Border Margin="0,22,0,0"
                        Padding="12"
                        Background="#0DFFFFFF"
                        CornerRadius="12">
                    <StackPanel>
                        <TextBlock FontWeight="SemiBold" Text="{Binding RootDisplayName}" />
                        <TextBlock Margin="0,5,0,0"
                                   FontSize="12"
                                   Foreground="#B6C9D7EA"
                                   Text="{Binding StatusText}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <TextBlock Margin="0,18,0,0"
                           FontSize="11"
                           Foreground="#8599A9C0"
                           Text="{Binding HostStatus}" />
            </StackPanel>
        </Border>

        <Border x:Name="SettingsHotspot"
                Width="72"
                Height="72"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Background="#01000000"
                MouseEnter="SettingsHotspot_OnMouseEnter"
                MouseLeave="SettingsHotspot_OnMouseLeave" />
    </Grid>
</Window>
